{% extends 'base.html.twig' %}

{% block title %}Trailmind | Easygoing Trail Days{% endblock %}

{% block body_class %}tm-root{% endblock %}

{% block body %}
    <div class="landing-page relative overflow-hidden">
        <div class="hero-glow hero-glow--left"></div>
        <div class="hero-glow hero-glow--right"></div>

        <main class="tm-shell">
            {{ component('ui:site_header', {
                brand: 'Trailmind',
                tagline: 'Casual trail planning for easy weekends',
                items: navigation,
            }) }}

            <section class="tm-hero-grid">
                <div class="max-w-3xl page-fade">
                    <span class="tm-kicker-badge">
                        Quietly ambitious hiking days
                    </span>

                    <h1 class="tm-hero-title">
                        A calm front porch for hikers who like their trails scenic, simple, and unhurried.
                    </h1>

                    <p class="tm-hero-copy">
                        Trailmind is a laid-back landing point for local loops, ridge walks, and weekend resets. No clutter, no pressure, just the feel of a good route and enough room to breathe.
                    </p>

                    <div class="tm-hero-actions">
                        <a class="tm-button-primary" href="#highlights">See the trail mood</a>
                        <a class="tm-button-secondary" href="#rhythm">Read the pace</a>
                    </div>

                    <div class="tm-feature-grid">
                        {% for feature in heroHighlights %}
                            {{ component('ui:feature_card', feature) }}
                        {% endfor %}
                    </div>
                </div>

                {{ component('ui:timeline_panel', {
                    eyebrow: 'Saturday rhythm',
                    title: 'Plan less. Wander better.',
                    entries: rhythmEntries,
                    summary: 'The page stays intentionally simple for now: one calm landing space, no external links, and a clear visual direction ready for trail features later.',
                    delay: '0.14s',
                }) }}
            </section>

            <section id="highlights" class="tm-trail-grid">
                {% for trail in trailHighlights %}
                    {{ component('ui:trail_card', trail) }}
                {% endfor %}
            </section>

            <section id="rhythm" class="tm-rhythm-grid">
                {{ component('ui:section_intro', {
                    eyebrow: 'Why it feels relaxed',
                    title: 'Because the best hiking pages feel like a conversation, not a command center.',
                    description: 'The design keeps the mood grounded and airy at once: warm earth tones, soft glassy surfaces, and a layout that encourages browsing without shouting for attention.',
                    delay: '0.18s',
                }) }}

                <div class="space-y-4 page-fade" style="animation-delay: 0.28s;">
                    {% for value in valueCards %}
                        {{ component('ui:value_card', value) }}
                    {% endfor %}
                </div>
            </section>

            {{ component('ui:outlook_banner', {
                id: 'outlook',
                eyebrow: 'Next trail markers',
                title: 'A simple landing page now, with plenty of room to grow into route discovery later.',
                description: 'This first pass keeps the experience focused: no external destinations, no extra flows, just a homepage with a steady voice and a trail-first atmosphere.',
                notes: outlookNotes,
                delay: '0.34s',
            }) }}
        </main>
    </div>
{% endblock %}