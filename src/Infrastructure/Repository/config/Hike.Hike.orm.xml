<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="
                    http://doctrine-project.org/schemas/orm/doctrine-mapping
                    https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="Trailmind\Hike\Hike" table="hikes">
        <id name="id" type="integer" column="id">
            <generator strategy="AUTO"/>
        </id>
        <many-to-one field="trail" target-entity="Trailmind\Trail\Trail" inversed-by="hikes">
            <join-column name="trail_id" referenced-column-name="id" nullable="false" on-delete="CASCADE"/>
        </many-to-one>
        <many-to-one field="user" target-entity="Trailmind\User\User" inversed-by="hikes">
            <join-column name="user_id" referenced-column-name="id" nullable="false" on-delete="CASCADE"/>
        </many-to-one>
        <field name="startDate" type="datetime_immutable" column="start_date" nullable="false"/>
        <field name="endDate" type="datetime_immutable" column="end_date" nullable="false"/>
    </entity>
</doctrine-mapping>
